print(push(values, 1), " ", values, "\n");
print(push(values, 2, 3), " ", values, "\n");

var alias = values;
print(push(alias, 4), " ", values, "\n");

print(pop(values), " ", values, "\n");
print(pop(values), " ", values, "\n");
print(pop(values), " ", values, "\n");
print(pop(values), " ", values, "\n");
